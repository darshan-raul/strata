# -*- mode: python -*-

REGISTRY = "localhost:5000"
NAMESPACE = "accio"

SERVICE_NAMES = [
    "auth-service",
    "catalog-service",
    "provisioner-service",
    "scorecard-service",
    "workflow-service",
    "audit-service",
    "portal-ui",
]

def build_service(name, context, port):
    img = REGISTRY + "/" + name + ":latest"
    docker_build(
        ref=img,
        context=context,
        dockerfile=context + "/Dockerfile",
    )
    return img

for svc in SERVICE_NAMES:
    build_service(svc, "./services/" + svc, 0)

k8s_yaml(kustomize("k8s/overlays/dev"))

allow_k8s_contexts("kind-accio")