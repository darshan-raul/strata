apiVersion: v1
kind: Secret
metadata:
  name: litellm-aws-credentials
  namespace: strata
  labels:
    app: litellm
    app.kubernetes.io/part-of: strata
type: Opaque
stringData:
  # Bedrock credentials. Copy this file to secret.yaml, fill in real values, and
  # `kubectl apply -f secret.yaml`. The real secret.yaml is gitignored.
  #
  # Phase 2/5: AWS access key + secret. Works on Kind and EKS.
  # Phase 5 (EKS only): swap to IRSA — delete this Secret, annotate the
  # litellm ServiceAccount with eks.amazonaws.com/role-arn, drop the
  # env vars from deployment.yaml. No other changes needed.
  AWS_ACCESS_KEY_ID: REPLACE_ME
  AWS_SECRET_ACCESS_KEY: REPLACE_ME
  AWS_REGION: us-east-1
  LITELLM_MASTER_KEY: sk-dev-strata-litellm-change-me
